text = input("Enter text: ")
shift = int(input("Enter shift: "))

result = ""

for ch in text:
    if ch.isalpha():
        if ch.isupper():
            result += chr((ord(ch) - 65 + shift) % 26 + 65)
        else:
            result += chr((ord(ch) - 97 + shift) % 26 + 97)
    else:
        result += ch

print("Cipher Text:", result)
