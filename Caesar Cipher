text = input("Enter text: ").upper()
k = int(input("Enter key: "))
cipher = ""
for ch in text:
    if ch.isalpha():
        cipher += chr((ord(ch) - 65 + k) % 26 + 65)
    else:
        cipher += ch
print("Encrypted:", cipher)
