text = input("Enter text: ").upper().replace(" ","")

if len(text) % 2 != 0:
    text += "X"

cipher = ""

for i in range(0, len(text), 2):
    a = ord(text[i]) - 65
    b = ord(text[i+1]) - 65

    c1 = (9*a + 4*b) % 26
    c2 = (5*a + 7*b) % 26

    cipher += chr(c1+65)
    cipher += chr(c2+65)

